{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "marknote",
  "version": "1.5.0",
  "identifier": "com.palamut62.marknote",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "marknote",
        "width": 1100,
        "height": 720,
        "minWidth": 640,
        "minHeight": 420,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [],
      "dialog": false,
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdx"],
        "name": "Markdown",
        "description": "Markdown document",
        "role": "Editor",
        "rank": "Alternate"
      }
    ]
  }
}
